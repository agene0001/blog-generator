# Copy to .env.local and fill in. .env.local is gitignored.

# Server-side default OpenAI key (optional — users can also bring their own
# key in the UI, which takes precedence over this one).
OPENAI_API_KEY=

# Optional: override the model used for blog generation (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Server-side default fal.ai key for image generation (optional — users can also
# bring their own fal key in the UI, which takes precedence).
FAL_KEY=

# Optional: override the image model (default: fal-ai/flux/schnell)
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# --- Supabase (auth + DB + image storage) ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
